DATABASE_URL="postgresql://pawn:pawn@localhost:5432/pawn_erp?schema=public"
PORT=3002
CORS_ORIGIN="http://localhost:5174"
CUSTOMER_ID_START=1000
ADMIN_SECURITY_PIN=1234
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# File storage: local (default) or s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
STORAGE_PUBLIC_BASE_URL=/api/v1/files
STORAGE_MAX_FILE_BYTES=5242880

# S3 (when STORAGE_DRIVER=s3)
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_URL=
